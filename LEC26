#include <iostream>
#include <string>
#include <cstdlib>
#include <ctime>

using namespace std;

struct Player {
    string name;
    char symbol;
    int wins;
    int losses;
    int draws;

    Player() : name(""), symbol('X'), wins(0), losses(0), draws(0) {}
};

Player player1("Игрок 1", 'X', 0, 0, 0);
Player player2("Игрок 2", 'O', 0, 0, 0);
Player computer("Компьютер", 'O', 0, 0, 0);

void clearScreen() {
    system("cls");
}

void printHeader(const string& title) {
    cout << "\n========== " << title << " ==========\n";
}

void drawBoard(char board[3][3]) {
    cout << "\n";
    cout << "     1   2   3\n";
    for (int i = 0; i < 3; i++) {
        cout << " " << i + 1 << " ";
        for (int j = 0; j < 3; j++) {
            cout << " " << board[i][j] << " ";
            if (j < 2) cout << "|";
        }
        cout << "\n";
        if (i < 2) cout << "    ---+---+---\n";
    }
    cout << "\n";
}

bool checkWin(char board[3][3], char symbol) {
    for (int i = 0; i < 3; i++) {
        if ((board[i][0] == symbol && board[i][1] == symbol && board[i][2] == symbol) ||
            (board[0][i] == symbol && board[1][i] == symbol && board[2][i] == symbol)) {
            return true;
        }
    }
    if ((board[0][0] == symbol && board[1][1] == symbol && board[2][2] == symbol) ||
        (board[0][2] == symbol && board[1][1] == symbol && board[2][0] == symbol)) {
        return true;
    }
    return false;
}

bool isBoardFull(char board[3][3]) {
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            if (board[i][j] == ' ') return false;
        }
    }
    return true;
}

void computerMove(char board[3][3]) {
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            if (board[i][j] == ' ') {
                board[i][j] = computer.symbol;
                return;
            }
        }
    }
}

void updateStats(Player& winner, Player& loser, bool isDraw = false) {
    if (isDraw) {
        player1.draws++;
        player2.draws++;
        computer.draws++;
    }
    else {
        winner.wins++;
        loser.losses++;
    }
}

void showStatistics() {
    clearScreen();
    printHeader("СТАТИСТИКА");
    cout << "\n";
    cout << "            Игрок 1   Игрок 2   Компьютер\n";
    cout << "Победы:     " << player1.wins << "         " << player2.wins << "         " << computer.wins << "\n";
    cout << "Поражения:  " << player1.losses << "         " << player2.losses << "         " << computer.losses << "\n";
    cout << "Ничьи:      " << player1.draws << "         " << player2.draws << "         " << computer.draws << "\n";

    float points1 = player1.wins * 5 + player1.losses * 6 + player1.draws * (-1.2);
    float points2 = player2.wins * 5 + player2.losses * 6 + player2.draws * (-1.2);
    float pointsComp = computer.wins * 5 + computer.losses * 6 + computer.draws * (-1.2);

    cout << "Очки:       " << points1 << "       " << points2 << "       " << pointsComp << "\n";

    cout << "\nНажмите Enter для возврата...";
    cin.ignore();
    cin.get();
}

void editPlayer(Player& player, int playerNum) {
    int choice;
    do {
        clearScreen();
        printHeader("НАСТРОЙКИ ИГРОКА " + to_string(playerNum));
        cout << "\n1. Ник: " << player.name;
        cout << "\n2. Фигура: " << player.symbol;
        cout << "\n0. Назад\n";
        cout << "Выбор: ";
        cin >> choice;
        cin.ignore();

        if (choice == 1) {
            cout << "Новый ник: ";
            getline(cin, player.name);
        }
        else if (choice == 2) {
            cout << "Новый символ: ";
            cin >> player.symbol;
        }
    } while (choice != 0);
}

void editComputer() {
    int choice;
    do {
        clearScreen();
        printHeader("НАСТРОЙКИ КОМПЬЮТЕРА");
        cout << "\n1. Фигура: " << computer.symbol;
        cout << "\n0. Назад\n";
        cout << "Выбор: ";
        cin >> choice;

        if (choice == 1) {
            cout << "Новый символ: ";
            cin >> computer.symbol;
        }
    } while (choice != 0);
}

void settingsMenu() {
    int choice;
    do {
        clearScreen();
        printHeader("НАСТРОЙКИ");
        cout << "\n1. Настройки игрока";
        cout << "\n2. Настройки компьютера";
        cout << "\n0. Назад\n";
        cout << "Выбор: ";
        cin >> choice;

        if (choice == 1) {
            int pChoice;
            cout << "\n1. Игрок 1\n2. Игрок 2\nВыбор: ";
            cin >> pChoice;
            if (pChoice == 1) editPlayer(player1, 1);
            else if (pChoice == 2) editPlayer(player2, 2);
        }
        else if (choice == 2) {
            editComputer();
        }
    } while (choice != 0);
}

void playGame(bool isSinglePlayer) {
    char board[3][3] = { {' ', ' ', ' '}, {' ', ' ', ' '}, {' ', ' ', ' '} };
    int currentPlayer = 1;
    int move;
    bool gameOver = false;

    while (!gameOver) {
        clearScreen();
        printHeader("КРЕСТИКИ-НОЛИКИ");
        drawBoard(board);

        if (currentPlayer == 1) {
            cout << "Ходит " << player1.name << " (" << player1.symbol << ")\n";
            cout << "Введите номер клетки (1-9): ";
            cin >> move;

            int row = (move - 1) / 3;
            int col = (move - 1) % 3;

            if (move >= 1 && move <= 9 && board[row][col] == ' ') {
                board[row][col] = player1.symbol;

                if (checkWin(board, player1.symbol)) {
                    clearScreen();
                    printHeader("ИГРА ОКОНЧЕНА");
                    drawBoard(board);
                    cout << "\nПОБЕДИЛ " << player1.name << "!\n";
                    updateStats(player1, isSinglePlayer ? computer : player2);
                    gameOver = true;
                }
                else if (isBoardFull(board)) {
                    clearScreen();
                    printHeader("ИГРА ОКОНЧЕНА");
                    drawBoard(board);
                    cout << "\nНИЧЬЯ!\n";
                    updateStats(player1, player2, true);
                    gameOver = true;
                }
                currentPlayer = 2;
            }
            else {
                cout << "Неверный ход! Нажмите Enter...";
                cin.ignore();
                cin.get();
            }
        }
        else {
            if (isSinglePlayer) {
                cout << "Ход компьютера...\n";
                computerMove(board);

                if (checkWin(board, computer.symbol)) {
                    clearScreen();
                    printHeader("ИГРА ОКОНЧЕНА");
                    drawBoard(board);
                    cout << "\nПОБЕДИЛ КОМПЬЮТЕР!\n";
                    updateStats(computer, player1);
                    gameOver = true;
                }
                else if (isBoardFull(board)) {
                    clearScreen();
                    printHeader("ИГРА ОКОНЧЕНА");
                    drawBoard(board);
                    cout << "\nНИЧЬЯ!\n";
                    updateStats(player1, computer, true);
                    gameOver = true;
                }
                currentPlayer = 1;
            }
            else {
                cout << "Ходит " << player2.name << " (" << player2.symbol << ")\n";
                cout << "Введите номер клетки (1-9): ";
                cin >> move;

                int row = (move - 1) / 3;
                int col = (move - 1) % 3;

                if (move >= 1 && move <= 9 && board[row][col] == ' ') {
                    board[row][col] = player2.symbol;

                    if (checkWin(board, player2.symbol)) {
                        clearScreen();
                        printHeader("ИГРА ОКОНЧЕНА");
                        drawBoard(board);
                        cout << "\nПОБЕДИЛ " << player2.name << "!\n";
                        updateStats(player2, player1);
                        gameOver = true;
                    }
                    else if (isBoardFull(board)) {
                        clearScreen();
                        printHeader("ИГРА ОКОНЧЕНА");
                        drawBoard(board);
                        cout << "\nНИЧЬЯ!\n";
                        updateStats(player1, player2, true);
                        gameOver = true;
                    }
                    currentPlayer = 1;
                }
                else {
                    cout << "Неверный ход! Нажмите Enter...";
                    cin.ignore();
                    cin.get();
                }
            }
        }
    }

    cout << "\nНажмите Enter для продолжения...";
    cin.ignore();
    cin.get();
}

int main() {
    setlocale(LC_ALL, "Russian");
    srand(time(0));

    int choice;

    do {
        clearScreen();
        printHeader("ГЛАВНОЕ МЕНЮ");
        cout << "\n1. Начать игру";
        cout << "\n2. Статистика";
        cout << "\n3. Настройки";
        cout << "\n4. Выйти";
        cout << "\n\nВыбор: ";
        cin >> choice;

        switch (choice) {
        case 1: {
            int gameMode;
            clearScreen();
            printHeader("ВЫБОР РЕЖИМА");
            cout << "\n1. Одиночная игра (с компьютером)";
            cout << "\n2. Два игрока";
            cout << "\n0. Назад\n";
            cout << "Выбор: ";
            cin >> gameMode;

            if (gameMode == 1) playGame(true);
            else if (gameMode == 2) playGame(false);
            break;
        }
        case 2:
            showStatistics();
            break;
        case 3:
            settingsMenu();
            break;
        case 4:
            cout << "\nДо свидания!\n";
            break;
        }
    } while (choice != 4);

    return 0;
}
